import java.io.*;
import java.util.*;

// ---------- MODEL ----------
class Reservation implements Serializable {
    String guestName;
    String roomType;
    String roomId;

    public Reservation(String guestName, String roomType, String roomId) {
        this.guestName = guestName;
        this.roomType = roomType;
        this.roomId = roomId;
    }

    public String toString() {
        return guestName + " -> " + roomType + " (" + roomId + ")";
    }
}

// ---------- INVENTORY ----------
class RoomInventory implements Serializable {
    private Map<String, Integer> inventory = new HashMap<>();

    public RoomInventory() {
        inventory.put("Single Room", 2);
        inventory.put("Double Room", 1);
    }

    public synchronized boolean allocate(String type) {
        int available = inventory.getOrDefault(type, 0);
        if (available > 0) {
            inventory.put(type, available - 1);
            return true;
        }
        return false;
    }

    public synchronized void increment(String type) {
        inventory.put(type, inventory.get(type) + 1);
    }

    public Map<String, Integer> getInventory() {
        return inventory;
    }
}

// ---------- QUEUE ----------
class BookingQueue {
    private Queue<Reservation> queue = new LinkedList<>();

    public synchronized void add(Reservation r) {
        queue.offer(r);
    }

    public synchronized Reservation get() {
        return queue.poll();
    }
}

// ---------- HISTORY ----------
class BookingHistory implements Serializable {
    List<Reservation> history = new ArrayList<>();

    public void add(Reservation r) {
        history.add(r);
    }

    public boolean remove(String roomId) {
        return history.removeIf(r -> r.roomId.equals(roomId));
    }

    public boolean exists(String roomId) {
        return history.stream().anyMatch(r -> r.roomId.equals(roomId));
    }
}

// ---------- VALIDATION ----------
class InvalidBookingException extends Exception {
    public InvalidBookingException(String msg) {
        super(msg);
    }
}

class BookingValidator {
    public void validate(String guest, String type, RoomInventory inventory)
            throws InvalidBookingException {

        if (guest == null || guest.isEmpty())
            throw new InvalidBookingException("Invalid guest name");

        if (!inventory.getInventory().containsKey(type))
            throw new InvalidBookingException("Invalid room type");

        if (inventory.getInventory().get(type) <= 0)
            throw new InvalidBookingException("No availability");
    }
}

// ---------- BOOKING SERVICE ----------
class BookingService {
    private int counter = 1;
    private BookingValidator validator = new BookingValidator();

    public Reservation book(String guest, String type,
                            RoomInventory inventory,
                            BookingHistory history)
            throws InvalidBookingException {

        validator.validate(guest, type, inventory);

        if (!inventory.allocate(type))
            throw new InvalidBookingException("Allocation failed");

        String roomId = type.replace(" ", "").toUpperCase() + "-" + counter++;

        Reservation r = new Reservation(guest, type, roomId);
        history.add(r);

        return r;
    }
}

// ---------- ADD-ON SERVICE ----------
class AddOnService {
    String name;
    double price;

    public AddOnService(String name, double price) {
        this.name = name;
        this.price = price;
    }
}

class AddOnManager {
    Map<String, List<AddOnService>> map = new HashMap<>();

    public void add(String id, AddOnService s) {
        map.putIfAbsent(id, new ArrayList<>());
        map.get(id).add(s);
    }

    public double total(String id) {
        double sum = 0;
        if (map.containsKey(id)) {
            for (AddOnService s : map.get(id)) sum += s.price;
        }
        return sum;
    }
}

// ---------- CANCELLATION ----------
class CancellationService {
    Stack<String> stack = new Stack<>();

    public void cancel(String roomId,
                       BookingHistory history,
                       RoomInventory inventory) {

        if (!history.exists(roomId)) {
            System.out.println("Cancel failed: Not found");
            return;
        }

        stack.push(roomId);
        history.remove(roomId);

        String type = roomId.startsWith("SINGLEROOM") ? "Single Room" : "Double Room";
        inventory.increment(type);

        System.out.println("Cancelled: " + roomId);
    }
}

// ---------- PERSISTENCE ----------
class SystemState implements Serializable {
    BookingHistory history;
    Map<String, Integer> inventory;

    public SystemState(BookingHistory h, Map<String, Integer> i) {
        history = h;
        inventory = i;
    }
}

class PersistenceService {
    String FILE = "state.ser";

    public void save(SystemState s) {
        try (ObjectOutputStream o = new ObjectOutputStream(new FileOutputStream(FILE))) {
            o.writeObject(s);
        } catch (Exception e) {
            System.out.println("Save error");
        }
    }

    public SystemState load() {
        try (ObjectInputStream i = new ObjectInputStream(new FileInputStream(FILE))) {
            return (SystemState) i.readObject();
        } catch (Exception e) {
            System.out.println("Fresh start");
            return null;
        }
    }
}

// ---------- MAIN APP ----------
public class MainApp {
    public static void main(String[] args) {

        PersistenceService ps = new PersistenceService();
        SystemState state = ps.load();

        BookingHistory history;
        RoomInventory inventory = new RoomInventory();

        if (state != null) {
            history = state.history;
            inventory.getInventory().putAll(state.inventory);
        } else {
            history = new BookingHistory();
        }

        BookingService booking = new BookingService();
        AddOnManager addOn = new AddOnManager();
        CancellationService cancel = new CancellationService();

        try {
            Reservation r1 = booking.book("Alice", "Single Room", inventory, history);
            System.out.println("Booked: " + r1);

            addOn.add(r1.roomId, new AddOnService("Breakfast", 500));
            System.out.println("Add-on cost: " + addOn.total(r1.roomId));

        } catch (Exception e) {
            System.out.println(e.getMessage());
        }

        cancel.cancel("SINGLEROOM-1", history, inventory);

        System.out.println("\nHistory:");
        for (Reservation r : history.history) {
            System.out.println(r);
        }

        ps.save(new SystemState(history, inventory.getInventory()));
    }
}
